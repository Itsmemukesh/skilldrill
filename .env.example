# Copy to `.env.local` for local development.
# For GitHub Pages production, set these as repository secrets in GitHub Actions.

# Google Analytics 4 measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=G-5MJRPETY0P

# Microsoft Clarity project ID (from Clarity → Settings → Setup)
NEXT_PUBLIC_CLARITY_ID=xmrxndigth

# Public site origin INCLUDING any subpath, no trailing slash.
# Used for canonical URLs, Open Graph, sitemap.xml, and robots.txt.
# Defaults to the GitHub Pages URL if unset.
NEXT_PUBLIC_SITE_URL=https://itsmemukesh.github.io/skilldrill

# Set automatically by the GitHub Pages workflow; leave unset locally.
# GITHUB_PAGES=true
# GITHUB_REPOSITORY=your-username/SkillDrill
