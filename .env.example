# Copy to `.env.local` for local development.
# For GitHub Pages production, set these as repository secrets in GitHub Actions.

# Google Analytics 4 measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Microsoft Clarity project ID
NEXT_PUBLIC_CLARITY_ID=

# Set automatically by the GitHub Pages workflow; leave unset locally.
# GITHUB_PAGES=true
# GITHUB_REPOSITORY=your-username/SkillDrill
